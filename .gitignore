# Dependency directories
# Node.js dependencies for both frontend and backend
node_modules/

# Environment variables
# This file contains sensitive information and should not be committed.
.env

# Build artifacts
# The output folder from your Vite build.
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.log*

# OS-related files
.DS_Store
Thumbs.db

